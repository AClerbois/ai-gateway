{
  "$schema": "./mcp-whitelist.schema.json",
  "metadata": {
    "version": "1.0.0",
    "description": "MCP Server Whitelisting Registry — approved MCP servers for the APIM gateway.",
    "lastUpdated": "2026-03-15",
    "maintainers": [
      "adrien@senseof.tech"
    ]
  },
  "approvedServers": [
    {
      "name": "mslearn-mcp",
      "displayName": "Microsoft Learn MCP Server",
      "publisher": "Microsoft",
      "source": "https://learn.microsoft.com/api/mcp",
      "sourceType": "managed-service",
      "transport": "streamable-http",
      "approvedVersions": ["*"],
      "securityReview": {
        "status": "approved",
        "reviewedBy": "platform-team",
        "reviewDate": "2026-03-01",
        "nextReviewDate": "2026-09-01",
        "riskLevel": "low",
        "notes": "Official Microsoft managed endpoint — no self-hosted code."
      },
      "restrictions": {
        "maxRateLimitPerMinute": 60,
        "allowedProfiles": ["*"],
        "requireEntraAuth": false
      }
    },
    {
      "name": "custom-mcp",
      "displayName": "Custom MCP Server",
      "publisher": "Sense of Tech",
      "source": "https://github.com/senseof-tech/custom-mcp-server",
      "sourceType": "internal",
      "transport": "streamable-http",
      "approvedVersions": ["1.x", "2.x"],
      "securityReview": {
        "status": "approved",
        "reviewedBy": "security-team",
        "reviewDate": "2026-02-15",
        "nextReviewDate": "2026-08-15",
        "riskLevel": "low",
        "notes": "Internal server — full code ownership and audit."
      },
      "restrictions": {
        "maxRateLimitPerMinute": 120,
        "allowedProfiles": ["*"],
        "requireEntraAuth": false
      }
    },
    {
      "name": "aoai-api",
      "displayName": "Azure OpenAI API",
      "publisher": "Microsoft",
      "source": "https://learn.microsoft.com/azure/ai-services/openai/",
      "sourceType": "managed-service",
      "transport": "https",
      "approvedVersions": ["*"],
      "securityReview": {
        "status": "approved",
        "reviewedBy": "platform-team",
        "reviewDate": "2026-03-01",
        "nextReviewDate": "2026-09-01",
        "riskLevel": "low",
        "notes": "Azure managed service with Managed Identity auth."
      },
      "restrictions": {
        "maxRateLimitPerMinute": 200,
        "maxTokensPerMinute": 20000,
        "allowedProfiles": ["*"],
        "requireEntraAuth": true
      }
    },
    {
      "name": "github-mcp",
      "displayName": "GitHub MCP Server",
      "publisher": "GitHub (modelcontextprotocol)",
      "source": "npm:@modelcontextprotocol/server-github",
      "sourceType": "open-source",
      "transport": "stdio",
      "approvedVersions": ["0.x", "1.x"],
      "securityReview": {
        "status": "approved",
        "reviewedBy": "security-team",
        "reviewDate": "2026-02-20",
        "nextReviewDate": "2026-08-20",
        "riskLevel": "medium",
        "notes": "Open-source, maintained by GitHub. Requires PAT — restrict scopes to minimum."
      },
      "restrictions": {
        "maxRateLimitPerMinute": 60,
        "allowedProfiles": ["developer", "app-1", "all-mcp-tools"],
        "requireEntraAuth": false,
        "requiredSecrets": ["GITHUB_PERSONAL_ACCESS_TOKEN"]
      },
      "mcpPrimitives": {
        "tools": {
          "policy": "denyList",
          "denied": ["delete_repository", "delete_branch", "delete_file"],
          "reason": "Destructive operations blocked by governance policy."
        },
        "prompts": {
          "policy": "allowAll"
        },
        "resources": {
          "policy": "allowAll"
        }
      }
    },
    {
      "name": "azuredevops-mcp",
      "displayName": "Azure DevOps MCP Server",
      "publisher": "Microsoft (AzureDevOps-MCP)",
      "source": "npm:@anthropic/azure-devops-mcp",
      "sourceType": "open-source",
      "transport": "stdio",
      "approvedVersions": ["0.x", "1.x"],
      "securityReview": {
        "status": "approved",
        "reviewedBy": "security-team",
        "reviewDate": "2026-02-20",
        "nextReviewDate": "2026-08-20",
        "riskLevel": "medium",
        "notes": "Requires Azure DevOps PAT — restrict scopes. Pin npm version in Dockerfile."
      },
      "restrictions": {
        "maxRateLimitPerMinute": 60,
        "allowedProfiles": ["developer", "all-mcp-tools"],
        "requireEntraAuth": false,
        "requiredSecrets": ["AZURE_DEVOPS_PAT"]
      },
      "mcpPrimitives": {
        "tools": {
          "policy": "allowList",
          "allowed": ["get_work_item", "list_work_items", "search_work_items", "get_pull_request", "list_pull_requests", "get_pipeline", "list_pipelines", "get_repository", "list_repositories"],
          "reason": "Only read operations allowed — write ops require separate approval."
        },
        "prompts": {
          "policy": "allowAll"
        },
        "resources": {
          "policy": "denyList",
          "denied": ["secret://*"],
          "reason": "Secret resources blocked for security."
        }
      }
    },
    {
      "name": "terraform-mcp",
      "displayName": "Terraform MCP Server",
      "publisher": "HashiCorp (hashicorp-forge)",
      "source": "npm:@hashicorp/terraform-mcp-server",
      "sourceType": "open-source",
      "transport": "stdio",
      "approvedVersions": ["0.x", "1.x"],
      "securityReview": {
        "status": "approved",
        "reviewedBy": "security-team",
        "reviewDate": "2026-03-01",
        "nextReviewDate": "2026-09-01",
        "riskLevel": "low",
        "notes": "Read-only documentation server. No credentials required."
      },
      "restrictions": {
        "maxRateLimitPerMinute": 60,
        "allowedProfiles": ["developer", "app-2", "all-mcp-tools"],
        "requireEntraAuth": false
      }
    },
    {
      "name": "snyk-mcp",
      "displayName": "Snyk MCP Server",
      "publisher": "Snyk",
      "source": "npm:snyk-mcp-server",
      "sourceType": "open-source",
      "transport": "stdio",
      "approvedVersions": ["0.x", "1.x"],
      "securityReview": {
        "status": "approved",
        "reviewedBy": "security-team",
        "reviewDate": "2026-03-05",
        "nextReviewDate": "2026-09-05",
        "riskLevel": "medium",
        "notes": "Security scanning — requires Snyk token. Ensure token has minimal scopes."
      },
      "restrictions": {
        "maxRateLimitPerMinute": 60,
        "allowedProfiles": ["developer", "app-2", "all-mcp-tools"],
        "requireEntraAuth": false,
        "requiredSecrets": ["SNYK_TOKEN"]
      }
    },
    {
      "name": "fluentui-blazor-mcp",
      "displayName": "Fluent UI Blazor MCP Server",
      "publisher": "Microsoft (AzureAaron)",
      "source": "npm:fluentui-blazor-mcp-server",
      "sourceType": "open-source",
      "transport": "stdio",
      "approvedVersions": ["0.x", "1.x"],
      "securityReview": {
        "status": "approved",
        "reviewedBy": "platform-team",
        "reviewDate": "2026-03-01",
        "nextReviewDate": "2026-09-01",
        "riskLevel": "low",
        "notes": "Documentation-only server, read-only, no credentials."
      },
      "restrictions": {
        "maxRateLimitPerMinute": 60,
        "allowedProfiles": ["developer", "all-mcp-tools"],
        "requireEntraAuth": false
      }
    }
  ],
  "blockedServers": [
    {
      "name": "example-blocked-server",
      "reason": "Known vulnerability CVE-2026-XXXXX — pending fix.",
      "blockedDate": "2026-03-10",
      "blockedBy": "security-team"
    }
  ],
  "policies": {
    "defaultAction": "deny",
    "requireSecurityReview": true,
    "maxReviewValidityDays": 180,
    "autoBlockOnExpiredReview": true,
    "allowUnreviewedInDev": false,
    "notifyOnExpiringSoon": 30,
    "mcpPrimitivesDefaults": {
      "tools": { "policy": "allowAll" },
      "prompts": { "policy": "allowAll" },
      "resources": { "policy": "allowAll" }
    }
  }
}
